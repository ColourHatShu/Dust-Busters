# Dust Busters — environment variables.
# Copy this file to `.env.local` and fill in real values. NEVER commit `.env.local`.

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
# Server-only. Bypasses RLS — keep secret, never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Stripe (Developers → API keys) ---
# Use test keys (sk_test_… / pk_test_…) until you go live.
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# From the Stripe webhook endpoint (Developers → Webhooks). Required for payments
# to advance bookings. Set after you create the webhook for <BASE_URL>/api/stripe/webhook.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- App ---
# The deployed origin (no trailing slash). Used for Stripe redirects, sitemap,
# robots, and Open Graph URLs. Use http://localhost:3000 in development.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
